<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#131313">

    <!-- Header Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#131313"
        android:padding="16dp"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Avatar/Helmet Placeholder -->
        <View
            android:id="@+id/avatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="#1C1B1B"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_gallery"
            app:tint="#E5E2E1"
            app:layout_constraintBottom_toBottomOf="@id/avatar"
            app:layout_constraintEnd_toEndOf="@id/avatar"
            app:layout_constraintStart_toStartOf="@id/avatar"
            app:layout_constraintTop_toTopOf="@id/avatar" />

        <TextView
            android:id="@+id/player_level"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            tools:text="LV. 1"
            android:textColor="#E9C176"
            android:textSize="9sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@id/avatar"
            app:layout_constraintStart_toStartOf="@id/avatar"
            app:layout_constraintTop_toBottomOf="@id/avatar" />

        <!-- HP Bar Area -->
        <LinearLayout
            android:id="@+id/hp_area"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:orientation="vertical"
            app:layout_constraintStart_toEndOf="@id/avatar"
            app:layout_constraintTop_toTopOf="parent">

            <!-- HP Bar Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:background="#0E0E0E"
                android:orientation="horizontal"
                android:weightSum="1">
                <View
                    android:id="@+id/hp_progress"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="#901418"
                    tools:layout_weight="0.7" />
            </LinearLayout>

            <TextView
                android:id="@+id/hp_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                tools:text="84 / 120"
                android:textColor="#E5E2E1"
                android:textSize="8sp"
                android:textStyle="bold" />

            <!-- XP Bar Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="6dp"
                android:background="#0E0E0E"
                android:orientation="horizontal"
                android:weightSum="1">
                <View
                    android:id="@+id/xp_progress"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="#E9C176"
                    android:alpha="0.4"
                    tools:layout_weight="0.3" />
            </LinearLayout>

            <TextView
                android:id="@+id/xp_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                tools:text="150 / 500"
                android:textColor="#E5E2E1"
                android:textSize="7sp"
                android:fontFamily="serif" />
        </LinearLayout>

        <!-- Stats Grid -->
        <GridLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:columnCount="2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Str (Strength) -->
            <LinearLayout android:padding="4dp" android:gravity="center_vertical" android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@android:drawable/ic_menu_compass" app:tint="#E0BFBA"/>
                <TextView android:id="@+id/stat_str" android:layout_width="wrap_content" android:layout_height="wrap_content" tools:text=" 14" android:textColor="#E9C176" android:textSize="10sp" android:textStyle="bold"/>
            </LinearLayout>
            <!-- Wis (Wisdom) -->
            <LinearLayout android:padding="4dp" android:gravity="center_vertical" android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@android:drawable/ic_menu_view" app:tint="#E0BFBA"/>
                <TextView android:id="@+id/stat_wis" android:layout_width="wrap_content" android:layout_height="wrap_content" tools:text=" 22" android:textColor="#E9C176" android:textSize="10sp" android:textStyle="bold"/>
            </LinearLayout>
            <!-- Health (Stat.health) -->
            <LinearLayout android:padding="4dp" android:gravity="center_vertical" android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@android:drawable/ic_menu_mylocation" app:tint="#E0BFBA"/>
                <TextView android:id="@+id/stat_health" android:layout_width="wrap_content" android:layout_height="wrap_content" tools:text=" 84" android:textColor="#E9C176" android:textSize="10sp" android:textStyle="bold"/>
            </LinearLayout>
            <!-- Agi (Agility) -->
            <LinearLayout android:padding="4dp" android:gravity="center_vertical" android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@android:drawable/ic_menu_slideshow" app:tint="#E0BFBA"/>
                <TextView android:id="@+id/stat_agi" android:layout_width="wrap_content" android:layout_height="wrap_content" tools:text=" 09" android:textColor="#E9C176" android:textSize="10sp" android:textStyle="bold"/>
            </LinearLayout>
        </GridLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Location Badge -->
    <TextView
        android:id="@+id/floor_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="#1C1B1B"
        android:paddingHorizontal="16dp"
        android:paddingVertical="4dp"
        tools:text="1F"
        android:textColor="#E9C176"
        android:fontFamily="serif"
        android:textStyle="italic"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Event Image -->
    <ImageView
        android:id="@+id/event_image"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:scaleType="centerCrop"
        tools:src="@drawable/mon_goblin"
        android:alpha="0.4"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/floor_number"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Scrollable Main Content (Narrative & Choices) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/event_image"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Narrative Text -->
            <TextView
                android:id="@+id/event_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:text="고블린과 마주쳤다"
                android:textColor="#E0BFBA"
                android:textSize="18sp"
                android:fontFamily="serif"
                android:textStyle="italic"
                android:layout_marginBottom="40dp" />

            <!-- Choices -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Choice 1 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/choice1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:letterSpacing="0.2"
                        android:textColor="#FFB3AD"
                        android:textSize="18sp"
                        tools:text="전투" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="2dp"
                        android:background="#FFB3AD" />
                </LinearLayout>

                <!-- Choice 2 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/choice2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:letterSpacing="0.2"
                        android:textColor="#FFB3AD"
                        android:textSize="18sp"
                        tools:text="피한다" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="2dp"
                        android:background="#FFB3AD" />
                </LinearLayout>

                <!-- Choice 3 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/choice3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:letterSpacing="0.2"
                        android:textColor="#FFB3AD"
                        android:textSize="18sp"
                        tools:text="WITHDRAW" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="2dp"
                        android:background="#FFB3AD" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#131313"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="#1C1B1B"
            android:layout_margin="8dp"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="#E9C176"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MAGIC"
                android:textColor="#E9C176"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="#1C1B1B"
            android:layout_margin="8dp"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_save"
                app:tint="#E9C176"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BAG"
                android:textColor="#E9C176"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="#1C1B1B"
            android:layout_margin="8dp"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_manage"
                app:tint="#E9C176"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SYSTEM"
                android:textColor="#E9C176"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>