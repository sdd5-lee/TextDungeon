<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1E1E1E"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_stat_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="능력치 분배"
        android:textColor="#E5E2E1"
        android:textSize="22sp"
        android:fontFamily="serif"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_remain_points"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#888888"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_stat_title"
        tools:text="남은 포인트: 3" />

    <TableLayout
        android:id="@+id/tableLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:stretchColumns="1"
        app:layout_constraintTop_toBottomOf="@id/tv_remain_points">

        <TableRow android:gravity="center_vertical" android:paddingVertical="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="힘" android:textColor="#E5E2E1" android:textSize="18sp"/>

            <TextView
                android:id="@+id/tv_str_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                tools:text="15" />
            <ImageButton android:id="@+id/btn_str_up" android:layout_width="40dp" android:layout_height="40dp" app:srcCompat="@android:drawable/ic_input_add" android:background="?android:attr/selectableItemBackground" app:tint="#888888"/>
        </TableRow>

        <View android:layout_height="1dp" android:background="#FFFFFF" android:alpha="0.3" android:layout_marginVertical="4dp"/>

        <TableRow android:gravity="center_vertical" android:paddingVertical="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="민첩" android:textColor="#E5E2E1" android:textSize="18sp"/>
            <TextView android:id="@+id/tv_agi_val" android:layout_width="wrap_content" android:layout_height="wrap_content" tools:text="12" android:textColor="#FFFFFF" android:textSize="18sp" android:gravity="center"/>
            <ImageButton android:id="@+id/btn_agi_up" android:layout_width="40dp" android:layout_height="40dp" app:srcCompat="@android:drawable/ic_input_add" android:background="?android:attr/selectableItemBackground" app:tint="#888888"/>
        </TableRow>

        <View android:layout_height="1dp" android:background="#FFFFFF" android:alpha="0.3" android:layout_marginVertical="4dp"/>

        <TableRow android:gravity="center_vertical" android:paddingVertical="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="체력" android:textColor="#E5E2E1" android:textSize="18sp"/>
            <TextView android:id="@+id/tv_vit_val" android:layout_width="wrap_content" android:layout_height="wrap_content" tools:text="14" android:textColor="#FFFFFF" android:textSize="18sp" android:gravity="center"/>
            <ImageButton android:id="@+id/btn_vit_up" android:layout_width="40dp" android:layout_height="40dp" app:srcCompat="@android:drawable/ic_input_add" android:background="?android:attr/selectableItemBackground" app:tint="#888888"/>
        </TableRow>

        <View android:layout_height="1dp" android:background="#FFFFFF" android:alpha="0.3" android:layout_marginVertical="4dp"/>

        <TableRow android:gravity="center_vertical" android:paddingVertical="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="지혜" android:textColor="#E5E2E1" android:textSize="18sp"/>
            <TextView android:id="@+id/tv_wis_val" android:layout_width="wrap_content" android:layout_height="wrap_content" tools:text="10" android:textColor="#FFFFFF" android:textSize="18sp" android:gravity="center"/>
            <ImageButton android:id="@+id/btn_wis_up" android:layout_width="40dp" android:layout_height="40dp" app:srcCompat="@android:drawable/ic_input_add" android:background="?android:attr/selectableItemBackground" app:tint="#888888"/>
        </TableRow>
        <View android:layout_height="1dp" android:background="#FFFFFF" android:alpha="0.3" android:layout_marginVertical="4dp"/>
    </TableLayout>

    <LinearLayout
        android:id="@+id/bottom_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tableLayout"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btn_reset_stat"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="초기화"
            android:textColor="#FFFFFF"
            android:backgroundTint="#333333" />

        <Button
            android:id="@+id/btn_confirm_stat"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="완료"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#555555" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>